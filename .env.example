# ============================================
# API Configuration Example
# ============================================
# 
# This file shows the available environment variables.
# Copy this to .env and customize as needed.
#
# By default, vite.config.js automatically handles:
# - Development: http://localhost:3001
# - Production: https://ecommerce-a5x-backend.onrender.com
#
# Override by uncommenting and setting:
# VITE_API_URL=http://localhost:3001

# ============================================
# For Vercel Deployment
# ============================================
# Set in Vercel Dashboard → Settings → Environment Variables:
# VITE_API_URL=https://ecommerce-a5x-backend.onrender.com
